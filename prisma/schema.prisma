generator client {
  provider     = "prisma-client"
  output       = "../src/lib/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

//
// ============================
// ENUMS
// ============================
//

enum RoleName {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PaymentMethod {
  CASH
  CARD
  BKASH
  NAGAD
  ROCKET
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

//
// ============================
// AUTH
// ============================
//

model Role {
  id          String   @id @default(cuid())
  name        RoleName @unique
  description String?

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

model User {
  id           String     @id @default(cuid())
  firstName    String
  lastName     String
  email        String     @unique
  phone        String?    @unique
  password     String
  avatar       String?

  status       UserStatus @default(ACTIVE)
  isVerified   Boolean    @default(false)
  lastLoginAt  DateTime?

  roleId String
  role   Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  refreshTokens RefreshToken[]
  orders         Order[]
  employee       Employee?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  revokedAt DateTime?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("refresh_tokens")
}

//
// ============================
// INVENTORY
// ============================
//

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  image       String?
  isActive    Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  sku           String   @unique
  barcode       String?  @unique
  description   String?

  purchasePrice Decimal
  sellingPrice  Decimal

  stock         Int      @default(0)
  minimumStock  Int      @default(0)

  thumbnail String?
  isActive  Boolean @default(true)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images ProductImage[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@map("products")
}

model ProductImage {
  id       String @id @default(cuid())
  imageUrl String

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("product_images")
}

//
// ============================
// SALES
// ============================
//

model Customer {
  id      String @id @default(cuid())

  name    String
  email   String? @unique
  phone   String  @unique
  address String?

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
}

model Order {
  id String @id @default(cuid())

  invoiceNo String @unique

  subtotal Decimal
  discount Decimal @default(0)
  tax      Decimal @default(0)
  total    Decimal

  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)
  status        OrderStatus   @default(PENDING)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Restrict)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id String @id @default(cuid())

  quantity  Int
  unitPrice Decimal
  subtotal  Decimal

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

//
// ============================
// SYSTEM
// ============================
//

model Employee {
  id String @id @default(cuid())

  designation String
  salary      Decimal?
  joiningDate DateTime

  userId String @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employees")
}

model Settings {
  id String @id @default(cuid())

  companyName    String
  companyEmail   String
  companyPhone   String
  companyAddress String

  logo     String?
  favicon  String?

  currency String @default("BDT")
  timezone String @default("Asia/Dhaka")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}