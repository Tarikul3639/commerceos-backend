<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
</head>

<body style="margin:0; background:#ffffff; color:#24292f; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif; font-size:14px; line-height:1.6;">

    <table width="100%" cellpadding="0" cellspacing="0" style="max-width:560px; margin:40px auto;">
        <tr>
            <td>

                <p style="margin:0 0 28px; font-size:18px; font-weight:700;">
                    {{appName}}
                </p>

                <h1 style="margin:0 0 12px; font-size:26px; font-weight:600;">
                    New order received
                </h1>

                <p style="margin:0 0 24px; color:#57606a;">
                    A new order has been placed by
                    <strong>{{customerName}}</strong>.
                </p>

                <table width="100%" cellpadding="12" cellspacing="0"
                    style="border:1px solid #d0d7de; border-collapse:separate; border-spacing:0; border-radius:8px;">

                    <tr>
                        <td style="color:#57606a;">Order</td>
                        <td align="right">
                            <strong>{{orderNumber}}</strong>
                        </td>
                    </tr>

                    <tr>
                        <td style="color:#57606a;">Customer</td>
                        <td align="right">{{customerName}}</td>
                    </tr>

                    <tr>
                        <td style="color:#57606a;">Email</td>
                        <td align="right">{{customerEmail}}</td>
                    </tr>

                    <tr>
                        <td style="color:#57606a;">Phone</td>
                        <td align="right">{{customerPhone}}</td>
                    </tr>

                    <tr>
                        <td style="color:#57606a;">Date</td>
                        <td align="right">{{orderDate}}</td>
                    </tr>

                    <tr>
                        <td style="color:#57606a;">Payment Method</td>
                        <td align="right">{{paymentMethod}}</td>
                    </tr>

                    <tr>
                        <td style="color:#57606a;">Payment Status</td>
                        <td align="right">{{paymentStatus}}</td>
                    </tr>

                    <tr>
                        <td style="color:#57606a;">Total</td>
                        <td align="right">
                            <strong>{{total}}</strong>
                        </td>
                    </tr>

                </table>

                <p style="margin:28px 0;">
                    <a href="{{orderUrl}}" style="display:inline-block; padding:10px 18px; background:#24292f; color:#ffffff; text-decoration:none; border-radius:6px; font-weight:500;">
                        View order
                    </a>
                </p>

                <hr style="border:none; border-top:1px solid #d8dee4; margin:0 0 20px;">

                <p style="margin:0 0 12px; color:#57606a;">
                    Please review the order and begin processing it as soon as possible.
                </p>

                <p style="margin:24px 0 0; font-size:13px; color:#8c959f;">
                    {{appName}}
                </p>

                <p style="margin:16px 0 0; font-size:12px; color:#8c959f;">
                    © {{year}} {{appName}}. All rights reserved.
                </p>

            </td>
        </tr>
    </table>

</body>

</html>