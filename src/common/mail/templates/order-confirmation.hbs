<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
</head>

<body style="margin:0; background:#ffffff; color:#24292f; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif; font-size:14px; line-height:1.6;">

    <table width="100%" cellpadding="0" cellspacing="0" style="max-width:560px; margin:40px auto;">
        <tr>
            <td>

                <p style="margin:0 0 28px; font-size:18px; font-weight:700;">
                    {{appName}}
                </p>

                <h1 style="margin:0 0 12px; font-size:26px; line-height:1.3; font-weight:600;">
                    Order confirmed
                </h1>

                <p style="margin:0 0 24px; color:#57606a;">
                    Hi <strong>{{customerName}}</strong>,
                    <br><br>
                    Thanks for your purchase. We've received your order and it's now being processed.
                    You'll receive another email when your order has been shipped.
                </p>

                <table width="100%" cellpadding="12" cellspacing="0" style="border:1px solid #d0d7de; border-radius:8px; border-collapse:separate; border-spacing:0;">
                    <tr>
                        <td style="color:#57606a;">Order</td>
                        <td align="right"><strong>{{orderNumber}}</strong></td>
                    </tr>
                    <tr>
                        <td style="color:#57606a;">Date</td>
                        <td align="right">{{orderDate}}</td>
                    </tr>
                    <tr>
                        <td style="color:#57606a;">Payment</td>
                        <td align="right">{{paymentMethod}}</td>
                    </tr>
                    <tr>
                        <td style="color:#57606a;">Status</td>
                        <td align="right">{{paymentStatus}}</td>
                    </tr>
                    <tr>
                        <td style="color:#57606a;">Total</td>
                        <td align="right"><strong>{{total}}</strong></td>
                    </tr>
                </table>

                <p style="margin:28px 0 24px;">
                    <a href="{{orderUrl}}" style="display:inline-block; padding:10px 18px; background:#24292f; color:#ffffff; text-decoration:none; border-radius:6px; font-weight:500;">
                        View order
                    </a>
                </p>

                <p style="margin:0 0 28px; color:#57606a;">
                    Need help? Just reply to this email and we'll be happy to assist you.
                </p>

                <hr style="border:none; border-top:1px solid #d8dee4; margin:0 0 20px;">

                <p style="margin:0; font-size:13px; color:#8c959f;">
                    Thanks,<br>
                    <strong>{{appName}}</strong>
                </p>

            </td>
        </tr>
    </table>

</body>

</html>