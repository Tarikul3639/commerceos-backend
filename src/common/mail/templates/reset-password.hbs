<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
</head>

<body style="margin:0; background:#ffffff; color:#24292f; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif; font-size:14px; line-height:1.6;">

    <table width="100%" cellpadding="0" cellspacing="0" style="max-width:560px; margin:40px auto;">
        <tr>
            <td>

                <p style="margin:0 0 28px; font-size:18px; font-weight:700;">
                    {{appName}}
                </p>

                <h1 style="margin:0 0 12px; font-size:26px; line-height:1.3; font-weight:600;">
                    Reset your password
                </h1>

                <p style="margin:0 0 24px; color:#57606a;">
                    Hi <strong>{{customerName}}</strong>,
                    <br><br>
                    We received a request to reset the password for your account.
                    If you made this request, click the button below to create a new password.
                </p>

                <p style="margin:28px 0;">
                    <a href="{{resetPasswordUrl}}" style="display:inline-block; padding:10px 18px; background:#24292f; color:#ffffff; text-decoration:none; border-radius:6px; font-weight:500;">
                        Reset password
                    </a>
                </p>

                <p style="margin:0 0 24px; color:#57606a;">
                    This link will expire in <strong>{{expireIn}}</strong>.
                </p>

                <p style="margin:0 0 24px; color:#57606a;">
                    If the button above doesn't work, copy and paste the following URL into your browser:
                </p>

                <p style="margin:0 0 28px; word-break:break-all;">
                    <a href="{{resetPasswordUrl}}" style="color:#0969da;">
                        {{resetPasswordUrl}}
                    </a>
                </p>

                <hr style="border:none; border-top:1px solid #d8dee4; margin:0 0 20px;">

                <p style="margin:0 0 12px; color:#57606a;">
                    If you didn't request a password reset, you can safely ignore this email.
                    Your password won't be changed.
                </p>

                <p style="margin:24px 0 0; font-size:13px; color:#8c959f;">
                    Thanks,<br>
                    <strong>{{appName}}</strong>
                </p>

                <p style="margin:16px 0 0; font-size:12px; color:#8c959f;">
                    © {{year}} {{appName}}. All rights reserved.
                </p>

            </td>
        </tr>
    </table>

</body>

</html>